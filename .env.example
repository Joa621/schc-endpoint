# Copy to .env and adjust paths before running.

# Absolute or relative path to the compiled schc-decompressor binary.
# Build it first: see README.md -> Build C decompressor.
DECOMPRESSOR_PATH=./build/src/schc-decompressor

# URL of the downstream logging application that receives decompressed frames.
# The endpoint POSTs JSON { "data": "<base64>", "devEui": "...", "fCnt": N, "time": "..." }
LOGGING_APP_URL=http://localhost:9090/sensor

# FastAPI bind address and port.
BIND_HOST=0.0.0.0
BIND_PORT=8080

# LoRaWAN FPort that carries SCHC-compressed frames. Frames on other FPorts are ignored.
EXPECTED_FPORT=10
